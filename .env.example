# Copy to .env and fill in. The .env file is ignored by Git.

# Jira Cloud site URL
JIRA_BASE_URL="https://SUAEMPRESA.atlassian.net"

# Atlassian account email
JIRA_EMAIL="voce@empresa.com"

# Jira API token generated at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=""

# Text/template used to find the issue when a time-sheet row is "daily" (optional)
# Supported placeholders: {date}, {year}, {month}, {month_number}, {month_name_en}, {month_name_pt}
JIRA_DAILY_SEARCH_TEXT="Daily {month_name_en} {year}"

# Optional project filter for daily issue resolution
JIRA_DAILY_PROJECT="PROJ"
