# Copy to .env and fill in. The .env file is optional and ignored by Git.
# The server also reads these from the MCP client environment.

# Active provider: "jira" (default), "redmine", "github", or "artia".
# WORK_PROVIDER="jira"

# --- Jira ---
# Jira Cloud site URL (HTTPS, must be a *.atlassian.net host)
JIRA_BASE_URL="https://your-site.atlassian.net"

# Atlassian account email
JIRA_EMAIL="you@example.com"

# Jira API token generated at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=""

# Optional. Resolves issue_key="daily" to a recurring monthly bucket issue.
# {month} = Portuguese month name, {year} = year, taken from the worklog date.
# Leave unset to disable daily resolution.
# JIRA_DAILY_JQL='project = MYPROJ AND summary ~ "Timesheet {month} de {year}" ORDER BY created DESC'

# --- Redmine (set WORK_PROVIDER="redmine" to use) ---
# Redmine base URL (HTTP or HTTPS; self-hosted intranet hosts allowed)
# REDMINE_URL="https://redmine.example.com"
# Redmine REST API key (My account > API access key)
# REDMINE_API_KEY=""
# Optional. Numeric activity id applied to every time entry. If unset, Redmine
# uses the project's default activity (POST fails if there is none).
# REDMINE_ACTIVITY_ID=""

# --- GitHub (set WORK_PROVIDER="github" to use) ---
# Personal access token with repo/issues read + issue-comment scope.
# GITHUB_TOKEN=""
# Optional. API base URL; override only for GitHub Enterprise.
# GITHUB_API_URL="https://api.github.com"
# Optional default repo ("owner/repo"); lets you pass a bare issue number and
# scopes default searches. Issue ids are "owner/repo#number" otherwise.
# GITHUB_REPO=""
# Note: GitHub has no time tracking — jira_log_work / jira_get_worklogs are
# unsupported under this provider; use jira_search_issues / jira_add_comment.

# --- Artia (set WORK_PROVIDER="artia" to use) ---
# Artia GraphQL endpoint. Default is https://api.artia.com/graphql.
# ARTIA_API_URL="https://api.artia.com/graphql"
# Artia ClientId.
# ARTIA_CLIENT_ID=""
# Artia Secret.
# ARTIA_SECRET=""
# Artia account/workspace id used by get_task and identity fallback.
# ARTIA_ACCOUNT_ID=""
# Default folder id used by search_tasks when native_query is omitted.
# ARTIA_FOLDER_ID=""
# Note: comments are unsupported; worklogs are supported in phase B.
