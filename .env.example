# Copie para .env e preencha. O .env é gitignorado — NUNCA versione.

# Jira Cloud — URL da sua instância
JIRA_BASE_URL="https://SUAEMPRESA.atlassian.net"

# Seu email da conta Atlassian
JIRA_EMAIL="voce@empresa.com"

# API token granular gerado em:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=""

# Projeto onde mora a tarefa mensal do daily (opcional; default GREDOM)
JIRA_DAILY_PROJECT="GREDOM"
